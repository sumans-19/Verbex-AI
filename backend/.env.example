# PostgreSQL
DATABASE_URL=postgresql+asyncpg://verbex:yourpassword@localhost:5432/verbex
DB_PASSWORD=yourpassword

# JWT
SECRET_KEY=your-random-string-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Gemini (free) — aistudio.google.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# OpenAI Whisper — for uploaded audio files
OPENAI_API_KEY=

# Deepgram — for live audio streaming
DEEPGRAM_API_KEY=

# App config
MAX_AUDIO_SIZE_MB=500
CONFIDENCE_AUTO_APPROVE=0.75
CONFIDENCE_REVIEW_THRESHOLD=0.50
