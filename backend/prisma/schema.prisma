datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = 5
}

enum MeetingStatus {
  pending
  transcribing
  processing
  complete
  failed
}

enum InputType {
  uploaded_audio
  text
  live_audio
}

enum TaskStatus {
  pending_review
  approved
  discarded
}

enum Priority {
  high
  medium
  low
}

model Meeting {
  id                String         @id @default(uuid())
  title             String
  host_name         String
  description       String?        @db.Text
  status            MeetingStatus  @default(pending)
  input_type        InputType?
  raw_file_path     String?
  raw_transcript    String?        @db.Text
  cleaned_transcript String?       @db.Text
  tldr              String?        @db.Text
  health_score      Float?
  created_at        DateTime       @default(now())
  processed_at      DateTime?
  tasks             Task[]
  decisions         Decision[]

  @@map("meetings")
}

model Task {
  id               String      @id @default(uuid())
  meeting_id       String
  title            String
  description      String?     @db.Text
  priority         Priority
  status           TaskStatus  @default(pending_review)
  confidence_score Float
  assignee_name    String?
  owner_emp_id     String?
  owner_dept       String?
  employee_id      String?
  source_quote     String?     @db.Text
  created_at       DateTime    @default(now())
  meeting          Meeting     @relation(fields: [meeting_id], references: [id])
  employee         Employee?   @relation(fields: [employee_id], references: [id])

  @@map("tasks")
}

model Employee {
  id              String   @id @default(uuid())
  name            String
  emp_id          String   @unique
  department      String?
  github_username String?
  created_at      DateTime @default(now())
  tasks           Task[]

  @@map("employees")
}

model Decision {
  id              String   @id @default(uuid())
  meeting_id      String
  title           String
  description     String?  @db.Text
  decided_by_name String?
  source_quote    String?  @db.Text
  created_at      DateTime @default(now())
  meeting         Meeting  @relation(fields: [meeting_id], references: [id])

  @@map("decisions")
}
